# =============================================================================
# Dev Homelab - Example Variables
# =============================================================================
# Copy this file to terraform.tfvars and customize if needed
# =============================================================================

# Host for service URLs (leave empty for automatic hostname.local detection)
# advertise_host = "192.168.1.100"

# Network configuration
network_name   = "dev_net"
network_subnet = "172.21.0.0/16"

# Whoami service
whoami_enabled = true
whoami_port    = 9080
