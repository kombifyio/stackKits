# kombify StackKits - Environment Variables
# Copy to .env and fill in values
#
# For subdirectory-specific env files, see also:
#   kombify-admin/.env.example
#   addons/vpn-overlay/.env.example

# === Database (Prisma) ===
# Port 5434 to avoid conflicts with local 5432; DB name is shared 'kombify'
DATABASE_URL="postgresql://kombify:kombify@localhost:5434/kombify?schema=public"

# === AI / API Keys ===
OPENAI_API_KEY=

# === Firecrawl ===
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# === n8n Integration ===
N8N_EXECUTION_ID=
N8N_WORKFLOW_ID=
