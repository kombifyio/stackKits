# =============================================================================
# PLATFORM: KUBERNETES - K3S INSTALLATION
# =============================================================================
# Layer 2 (PLATFORM): Lightweight Kubernetes (k3s) for HA deployments
#
# This template provides:
# - K3s single-node or multi-node cluster setup
# - Automatic TLS (Traefik built-in)
# - Optional components (metrics-server, local-path-provisioner)
# =============================================================================

# -----------------------------------------------------------------------------
# VARIABLES
# -----------------------------------------------------------------------------

variable "k3s_enabled" {
  description = "Deploy k3s Kubernetes cluster"
  type        = bool
  default     = true
}

variable "k3s_version" {
  description = "K3s version to install"
  type        = string
  default     = "v1.30.2+k3s1"
}

variable "k3s_role" {
  description = "Node role: server (control plane) or agent (worker)"
  type        = string
  default     = "server"
}

variable "k3s_server_url" {
  description = "URL of the k3s server (for agent nodes)"
  type        = string
  default     = ""
}

variable "k3s_token" {
  description = "Token for joining the cluster"
  type        = string
  default     = ""
  sensitive   = true
}

variable "k3s_disable_components" {
  description = "Components to disable"
  type        = list(string)
  default     = []
}

variable "k3s_tls_san" {
  description = "Additional SANs for the API server certificate"
  type        = list(string)
  default     = []
}

variable "k3s_flannel_backend" {
  description = "Flannel backend type"
  type        = string
  default     = "vxlan"
}

variable "k3s_cluster_cidr" {
  description = "CIDR for pod network"
  type        = string
  default     = "10.42.0.0/16"
}

variable "k3s_service_cidr" {
  description = "CIDR for service network"
  type        = string
  default     = "10.43.0.0/16"
}

# -----------------------------------------------------------------------------
# K3S INSTALLATION - SERVER NODE
# -----------------------------------------------------------------------------

resource "null_resource" "k3s_server" {
  count = var.k3s_enabled && var.k3s_role == "server" ? 1 : 0

  connection {
    type        = local.ssh_connection.type
    host        = local.ssh_connection.host
    user        = local.ssh_connection.user
    private_key = local.ssh_connection.private_key
    timeout     = local.ssh_connection.timeout
  }

  provisioner "remote-exec" {
    inline = [
      "#!/bin/bash",
      "set -e",
      
      "echo '=== PLATFORM: Installing K3s Server ==='",
      
      "# Check if k3s is already installed",
      "if command -v k3s &> /dev/null; then",
      "  echo 'K3s already installed, checking version...'",
      "  CURRENT_VERSION=$(k3s --version | head -1 | awk '{print $3}')",
      "  if [ \"$CURRENT_VERSION\" == '${var.k3s_version}' ]; then",
      "    echo 'K3s version matches, skipping installation'",
      "    exit 0",
      "  fi",
      "  echo 'Upgrading k3s...'",
      "fi",
      
      "# Build installation options",
      "INSTALL_K3S_EXEC='server'",
      
      "# Add disabled components",
      "%{ for component in var.k3s_disable_components ~}",
      "INSTALL_K3S_EXEC=\"$INSTALL_K3S_EXEC --disable ${component}\"",
      "%{ endfor ~}",
      
      "# Add TLS SANs",
      "%{ for san in var.k3s_tls_san ~}",
      "INSTALL_K3S_EXEC=\"$INSTALL_K3S_EXEC --tls-san ${san}\"",
      "%{ endfor ~}",
      
      "# Add network configuration",
      "INSTALL_K3S_EXEC=\"$INSTALL_K3S_EXEC --flannel-backend=${var.k3s_flannel_backend}\"",
      "INSTALL_K3S_EXEC=\"$INSTALL_K3S_EXEC --cluster-cidr=${var.k3s_cluster_cidr}\"",
      "INSTALL_K3S_EXEC=\"$INSTALL_K3S_EXEC --service-cidr=${var.k3s_service_cidr}\"",
      
      "# Download and install k3s",
      "curl -sfL https://get.k3s.io | \\",
      "  INSTALL_K3S_VERSION='${var.k3s_version}' \\",
      "  INSTALL_K3S_EXEC=\"$INSTALL_K3S_EXEC\" \\",
      "  sh -",
      
      "# Wait for k3s to be ready",
      "echo 'Waiting for k3s to start...'",
      "for i in {1..60}; do",
      "  if kubectl get nodes &> /dev/null; then",
      "    echo 'K3s is ready!'",
      "    break",
      "  fi",
      "  sleep 5",
      "done",
      
      "# Show node status",
      "kubectl get nodes -o wide",
      
      "# Copy kubeconfig to standard location",
      "mkdir -p ~/.kube",
      "cp /etc/rancher/k3s/k3s.yaml ~/.kube/config",
      "chmod 600 ~/.kube/config",
      
      "# Get the token for agent nodes",
      "echo '=== K3s Token (for agent nodes) ==='",
      "cat /var/lib/rancher/k3s/server/node-token",
      
      "echo '=== K3s Server installed ==='",
    ]
  }
}

# -----------------------------------------------------------------------------
# K3S INSTALLATION - AGENT NODE
# -----------------------------------------------------------------------------

resource "null_resource" "k3s_agent" {
  count = var.k3s_enabled && var.k3s_role == "agent" ? 1 : 0

  connection {
    type        = local.ssh_connection.type
    host        = local.ssh_connection.host
    user        = local.ssh_connection.user
    private_key = local.ssh_connection.private_key
    timeout     = local.ssh_connection.timeout
  }

  provisioner "remote-exec" {
    inline = [
      "#!/bin/bash",
      "set -e",
      
      "echo '=== PLATFORM: Installing K3s Agent ==='",
      
      "# Validate required variables",
      "if [ -z '${var.k3s_server_url}' ]; then",
      "  echo 'ERROR: k3s_server_url is required for agent nodes'",
      "  exit 1",
      "fi",
      
      "if [ -z '${var.k3s_token}' ]; then",
      "  echo 'ERROR: k3s_token is required for agent nodes'",
      "  exit 1",
      "fi",
      
      "# Download and install k3s agent",
      "curl -sfL https://get.k3s.io | \\",
      "  INSTALL_K3S_VERSION='${var.k3s_version}' \\",
      "  K3S_URL='${var.k3s_server_url}' \\",
      "  K3S_TOKEN='${var.k3s_token}' \\",
      "  sh -",
      
      "echo '=== K3s Agent installed ==='",
    ]
  }
}

# -----------------------------------------------------------------------------
# KUBECTL CONFIGURATION
# -----------------------------------------------------------------------------

resource "null_resource" "k3s_kubectl_config" {
  count = var.k3s_enabled && var.k3s_role == "server" ? 1 : 0

  depends_on = [null_resource.k3s_server]

  connection {
    type        = local.ssh_connection.type
    host        = local.ssh_connection.host
    user        = local.ssh_connection.user
    private_key = local.ssh_connection.private_key
    timeout     = local.ssh_connection.timeout
  }

  provisioner "remote-exec" {
    inline = [
      "#!/bin/bash",
      "set -e",
      
      "echo '=== PLATFORM: Configuring kubectl ==='",
      
      "# Install kubectl bash completion",
      "echo 'source <(kubectl completion bash)' >> ~/.bashrc",
      "echo 'alias k=kubectl' >> ~/.bashrc",
      "echo 'complete -F __start_kubectl k' >> ~/.bashrc",
      
      "# Create kombistack namespace",
      "kubectl create namespace kombistack --dry-run=client -o yaml | kubectl apply -f -",
      
      "# Set default namespace",
      "kubectl config set-context --current --namespace=kombistack",
      
      "echo '=== kubectl configured ==='",
    ]
  }
}

# -----------------------------------------------------------------------------
# OUTPUTS
# -----------------------------------------------------------------------------

output "k3s_enabled" {
  value       = var.k3s_enabled
  description = "Whether k3s is enabled"
}

output "k3s_role" {
  value       = var.k3s_role
  description = "Node role (server or agent)"
}

output "k3s_kubeconfig_path" {
  value       = var.k3s_enabled && var.k3s_role == "server" ? "~/.kube/config" : ""
  description = "Path to kubeconfig file"
}
