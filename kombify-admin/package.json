{
  "name": "kombify-admin",
  "version": "2.0.0",
  "description": "kombify Administration - Central StackKits management platform with tool discovery, evaluation, and CUE generation",
  "main": "index.js",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "generate:cue": "ts-node scripts/generate-cue.ts",
    "generate:cue:all": "ts-node scripts/generate-cue.ts all",
    "generate:cue:validation": "ts-node scripts/generate-cue.ts validation-rules",
    "generate:cue:settings": "ts-node scripts/generate-cue.ts settings",
    "generate:cue:addons": "ts-node scripts/generate-cue.ts addons",
    "generate:cue:contexts": "ts-node scripts/generate-cue.ts contexts",
    "generate:cue:tools": "ts-node scripts/generate-cue.ts tool-catalog",
    "discover": "ts-node scripts/tool-discover.ts",
    "discover:category": "ts-node scripts/tool-discover.ts",
    "discover:dry-run": "ts-node scripts/tool-discover.ts --dry-run",
    "enrich": "ts-node scripts/tool-enrich.ts",
    "enrich:discovered": "ts-node scripts/tool-enrich.ts --discovered",
    "enrich:all": "ts-node scripts/tool-enrich.ts --all",
    "version-check": "ts-node scripts/tool-version-check.ts --all",
    "review": "ts-node scripts/tool-review.ts",
    "review:summary": "ts-node scripts/tool-review.ts --summary",
    "pipeline": "npm run discover && npm run enrich:discovered && npm run review:summary"
  },
  "keywords": [
    "stackkits",
    "kombify",
    "administration",
    "cue",
    "validation",
    "tool-discovery",
    "firecrawl"
  ],
  "author": "kombify Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^5.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
