# =============================================================================
# PLATFORM IDENTITY - TinyAuth (Identity Proxy & ForwardAuth)
# =============================================================================
# Layer 2 (PLATFORM): Applied when platform identity is enabled
#
# This template deploys TinyAuth as a Traefik ForwardAuth middleware:
# - Lightweight identity proxy for application authentication
# - Integrates with OIDC providers (PocketID, external)
# - Registers as Traefik ForwardAuth middleware automatically
# - Supports local users, GitHub/Google OAuth, and generic OIDC
#
# DEPENDENCY: Requires Traefik (from PaaS layer) and optionally LLDAP + PocketID
# =============================================================================

# -----------------------------------------------------------------------------
# VARIABLES
# -----------------------------------------------------------------------------

variable "tinyauth_enabled" {
  description = "Enable TinyAuth identity proxy"
  type        = bool
  default     = false
}

variable "tinyauth_version" {
  description = "TinyAuth Docker image version"
  type        = string
  default     = "v3"
}

variable "tinyauth_port" {
  description = "TinyAuth HTTP port"
  type        = number
  default     = 3002
}

variable "tinyauth_app_url" {
  description = "Public URL for TinyAuth (e.g., https://auth.example.com)"
  type        = string
  default     = "https://auth.stack.local"
}

variable "tinyauth_traefik_host" {
  description = "Traefik host rule for TinyAuth"
  type        = string
  default     = "auth.stack.local"
}

variable "tinyauth_session_secret" {
  description = "Session secret for TinyAuth (use secret management in production)"
  type        = string
  sensitive   = true
  default     = "change-me-in-production"
}

variable "tinyauth_log_level" {
  description = "Log level for TinyAuth"
  type        = string
  default     = "info"

  validation {
    condition     = contains(["debug", "info", "warn", "error"], var.tinyauth_log_level)
    error_message = "Log level must be one of: debug, info, warn, error"
  }
}

# OIDC provider configuration (connects to PocketID or external OIDC)
variable "tinyauth_oidc_enabled" {
  description = "Enable OIDC provider integration"
  type        = bool
  default     = false
}

variable "tinyauth_oidc_issuer" {
  description = "OIDC issuer URL (e.g., PocketID URL)"
  type        = string
  default     = ""
}

variable "tinyauth_oidc_client_id" {
  description = "OIDC client ID"
  type        = string
  default     = ""
}

variable "tinyauth_oidc_client_secret" {
  description = "OIDC client secret"
  type        = string
  sensitive   = true
  default     = ""
}

# GitHub OAuth (optional)
variable "tinyauth_github_enabled" {
  description = "Enable GitHub OAuth provider"
  type        = bool
  default     = false
}

variable "tinyauth_github_client_id" {
  description = "GitHub OAuth client ID"
  type        = string
  default     = ""
}

variable "tinyauth_github_client_secret" {
  description = "GitHub OAuth client secret"
  type        = string
  sensitive   = true
  default     = ""
}

# Google OAuth (optional)
variable "tinyauth_google_enabled" {
  description = "Enable Google OAuth provider"
  type        = bool
  default     = false
}

variable "tinyauth_google_client_id" {
  description = "Google OAuth client ID"
  type        = string
  default     = ""
}

variable "tinyauth_google_client_secret" {
  description = "Google OAuth client secret"
  type        = string
  sensitive   = true
  default     = ""
}

# Traefik ForwardAuth middleware name
variable "tinyauth_middleware_name" {
  description = "Name for the Traefik ForwardAuth middleware"
  type        = string
  default     = "tinyauth"
}

# Docker network to join (must match PaaS/identity network)
variable "tinyauth_network" {
  description = "Docker network name to attach to"
  type        = string
  default     = "identity_net"
}

# -----------------------------------------------------------------------------
# TINYAUTH VOLUME
# -----------------------------------------------------------------------------

resource "docker_volume" "tinyauth_data" {
  count = var.tinyauth_enabled ? 1 : 0
  name  = "tinyauth-data"
}

# -----------------------------------------------------------------------------
# TINYAUTH CONTAINER
# -----------------------------------------------------------------------------

resource "docker_container" "tinyauth" {
  count = var.tinyauth_enabled ? 1 : 0

  name  = "tinyauth"
  image = "ghcr.io/steveiliop56/tinyauth:${var.tinyauth_version}"

  restart = "unless-stopped"

  networks_advanced {
    name = var.tinyauth_network
  }

  # Ports
  ports {
    internal = 3000
    external = var.tinyauth_port
    protocol = "tcp"
  }

  # Volumes
  volumes {
    volume_name    = docker_volume.tinyauth_data[0].name
    container_path = "/data"
  }

  # Environment
  env = concat(
    [
      "TZ=Europe/Berlin",
      "APP_URL=${var.tinyauth_app_url}",
      "LOG_LEVEL=${var.tinyauth_log_level}",
      "SESSION_SECRET=${var.tinyauth_session_secret}",
    ],
    # OIDC provider (PocketID or external)
    var.tinyauth_oidc_enabled ? [
      "OIDC_ENABLED=true",
      "OIDC_ISSUER=${var.tinyauth_oidc_issuer}",
      "OIDC_CLIENT_ID=${var.tinyauth_oidc_client_id}",
      "OIDC_CLIENT_SECRET=${var.tinyauth_oidc_client_secret}",
    ] : [],
    # GitHub OAuth
    var.tinyauth_github_enabled ? [
      "GITHUB_ENABLED=true",
      "GITHUB_CLIENT_ID=${var.tinyauth_github_client_id}",
      "GITHUB_CLIENT_SECRET=${var.tinyauth_github_client_secret}",
    ] : [],
    # Google OAuth
    var.tinyauth_google_enabled ? [
      "GOOGLE_ENABLED=true",
      "GOOGLE_CLIENT_ID=${var.tinyauth_google_client_id}",
      "GOOGLE_CLIENT_SECRET=${var.tinyauth_google_client_secret}",
    ] : [],
  )

  # Healthcheck
  healthcheck {
    test     = ["CMD", "wget", "-q", "--spider", "http://localhost:3000/api/health"]
    interval = "30s"
    timeout  = "5s"
    retries  = 3
  }

  # Traefik labels — router for TinyAuth UI
  labels {
    label = "traefik.enable"
    value = "true"
  }

  labels {
    label = "traefik.http.routers.tinyauth.entrypoints"
    value = "websecure"
  }

  labels {
    label = "traefik.http.routers.tinyauth.rule"
    value = "Host(`${var.tinyauth_traefik_host}`)"
  }

  labels {
    label = "traefik.http.routers.tinyauth.tls.certresolver"
    value = "letsencrypt"
  }

  labels {
    label = "traefik.http.services.tinyauth.loadbalancer.server.port"
    value = "3000"
  }

  # Traefik ForwardAuth middleware — other services reference this middleware
  # Usage: add label "traefik.http.routers.myapp.middlewares=tinyauth" to any service
  labels {
    label = "traefik.http.middlewares.${var.tinyauth_middleware_name}.forwardauth.address"
    value = "http://tinyauth:3000/api/auth/verify"
  }

  labels {
    label = "traefik.http.middlewares.${var.tinyauth_middleware_name}.forwardauth.authResponseHeaders"
    value = "X-User,X-Email"
  }

  # StackKit classification labels
  labels {
    label = "stackkit.layer"
    value = "2-platform"
  }

  labels {
    label = "stackkit.managed-by"
    value = "terraform"
  }

  labels {
    label = "stackkit.category"
    value = "platform-identity"
  }

  labels {
    label = "stackkit.identity-provider"
    value = "tinyauth"
  }

  depends_on = [docker_volume.tinyauth_data]
}

# -----------------------------------------------------------------------------
# OUTPUT
# -----------------------------------------------------------------------------

output "tinyauth_enabled" {
  value       = var.tinyauth_enabled
  description = "Whether TinyAuth is enabled"
}

output "tinyauth_url" {
  value       = var.tinyauth_enabled ? var.tinyauth_app_url : ""
  description = "TinyAuth UI URL"
}

output "tinyauth_middleware" {
  value       = var.tinyauth_enabled ? var.tinyauth_middleware_name : ""
  description = "Traefik ForwardAuth middleware name (use in other service labels)"
}

output "tinyauth_forwardauth_url" {
  value       = var.tinyauth_enabled ? "http://tinyauth:3000/api/auth/verify" : ""
  description = "ForwardAuth verification URL for Traefik middleware"
}
