# =============================================================================
# CORE: SECURITY - FAIL2BAN PROTECTION
# =============================================================================
# Layer 1 (CORE): Applied to ALL deployments
#
# This template installs and configures fail2ban:
# - Protects SSH against brute-force attacks
# - Configurable ban time and retry limits
# - Optional Docker-aware jail
# =============================================================================

# -----------------------------------------------------------------------------
# VARIABLES
# -----------------------------------------------------------------------------

variable "fail2ban_enabled" {
  description = "Enable fail2ban installation and configuration"
  type        = bool
  default     = true
}

variable "fail2ban_ban_time" {
  description = "Ban duration in seconds (default: 1 hour)"
  type        = number
  default     = 3600
}

variable "fail2ban_find_time" {
  description = "Time window for counting failures in seconds"
  type        = number
  default     = 600
}

variable "fail2ban_max_retry" {
  description = "Number of failures before ban"
  type        = number
  default     = 5
}

# -----------------------------------------------------------------------------
# FAIL2BAN INSTALLATION
# -----------------------------------------------------------------------------

resource "null_resource" "fail2ban_install" {
  count = var.fail2ban_enabled ? 1 : 0

  depends_on = [null_resource.ssh_restart]

  connection {
    type        = local.ssh_connection.type
    host        = local.ssh_connection.host
    user        = local.ssh_connection.user
    private_key = local.ssh_connection.private_key
    timeout     = local.ssh_connection.timeout
  }

  provisioner "remote-exec" {
    inline = [
      "#!/bin/bash",
      "set -e",
      
      "echo '=== CORE: Installing Fail2ban ==='",
      
      "# Install fail2ban",
      "if command -v apt-get &> /dev/null; then",
      "  apt-get install -y fail2ban",
      "elif command -v dnf &> /dev/null; then",
      "  dnf install -y fail2ban",
      "else",
      "  echo 'Package manager not supported'",
      "  exit 1",
      "fi",
      
      "echo '=== Fail2ban installed ==='",
    ]
  }
}

# -----------------------------------------------------------------------------
# FAIL2BAN CONFIGURATION
# -----------------------------------------------------------------------------

resource "null_resource" "fail2ban_config" {
  count = var.fail2ban_enabled ? 1 : 0

  depends_on = [null_resource.fail2ban_install]

  connection {
    type        = local.ssh_connection.type
    host        = local.ssh_connection.host
    user        = local.ssh_connection.user
    private_key = local.ssh_connection.private_key
    timeout     = local.ssh_connection.timeout
  }

  provisioner "remote-exec" {
    inline = [
      "#!/bin/bash",
      "set -e",
      
      "echo '=== CORE: Configuring Fail2ban ==='",
      
      "# Create local configuration",
      "cat > /etc/fail2ban/jail.local << 'EOF'",
      "[DEFAULT]",
      "# Ban duration",
      "bantime = ${var.fail2ban_ban_time}",
      "",
      "# Time window for counting failures",
      "findtime = ${var.fail2ban_find_time}",
      "",
      "# Max retries before ban",
      "maxretry = ${var.fail2ban_max_retry}",
      "",
      "# Ignore localhost",
      "ignoreip = 127.0.0.1/8 ::1",
      "",
      "# Default action: ban IP with UFW",
      "banaction = ufw",
      "",
      "[sshd]",
      "enabled = true",
      "port = ssh",
      "filter = sshd",
      "logpath = /var/log/auth.log",
      "maxretry = ${var.fail2ban_max_retry}",
      "EOF",
      
      "echo '=== Fail2ban configuration created ==='",
    ]
  }
}

# -----------------------------------------------------------------------------
# FAIL2BAN START
# -----------------------------------------------------------------------------

resource "null_resource" "fail2ban_start" {
  count = var.fail2ban_enabled ? 1 : 0

  depends_on = [null_resource.fail2ban_config]

  connection {
    type        = local.ssh_connection.type
    host        = local.ssh_connection.host
    user        = local.ssh_connection.user
    private_key = local.ssh_connection.private_key
    timeout     = local.ssh_connection.timeout
  }

  provisioner "remote-exec" {
    inline = [
      "#!/bin/bash",
      "set -e",
      
      "echo '=== CORE: Starting Fail2ban ==='",
      
      "# Enable and start fail2ban",
      "systemctl enable fail2ban",
      "systemctl restart fail2ban",
      
      "# Show status",
      "fail2ban-client status",
      
      "echo '=== Fail2ban started ==='",
    ]
  }
}

# -----------------------------------------------------------------------------
# OUTPUT
# -----------------------------------------------------------------------------

output "fail2ban_enabled" {
  value       = var.fail2ban_enabled
  description = "Whether fail2ban is enabled"
}
