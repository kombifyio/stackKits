#!/bin/bash
# =============================================================================
# Pre-commit hook: Enforce banned external port defaults
# =============================================================================
# Prevents commits that introduce ports 3000 or 3001 as external/host port
# defaults in configuration files.
#
# ALLOWED (internal container ports - app listens on these):
#   - internal = 3000                    (TF: container internal port)
#   - loadbalancer.server.port=3000      (Traefik label: internal port)
#   - http://localhost:3000/             (healthcheck inside container)
#   - PORT=3000                          (env var: app internal port)
#   - http://tinyauth:3000/              (container-to-container)
#
# BANNED (external/host port defaults):
#   - default = 3000                     (TF variable default)
#   - default     = 3001                 (TF variable default)
#   - "3000:3000"                        (docker-compose port mapping)
#   - "3001:3001"                        (docker-compose port mapping)
#   - VM_DOKPLOY_PORT:-3000              (env var default)
#   - DOKPLOY_PORT:-3000                 (env var default)
# =============================================================================

set -e

# Only check staged files that are being committed
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

ERRORS=0

for file in $STAGED_FILES; do
    # Skip binary files, archives, and non-config files
    case "$file" in
        *.png|*.jpg|*.gif|*.ico|*.woff|*.ttf|*.eot|*.svg|*.zip|*.tar|*.gz)
            continue
            ;;
        # Skip archived docs - they're historical
        docs/_archive/*)
            continue
            ;;
        # Skip the hook itself - its comments contain example patterns
        .githooks/*)
            continue
            ;;
    esac

    # Get only the staged content (what will be committed)
    STAGED_CONTENT=$(git show ":$file" 2>/dev/null || continue)

    # Pattern 1: TF variable defaults like "default = 3000" or "default     = 3001"
    if echo "$STAGED_CONTENT" | grep -nP '^\s*default\s*=\s*(3000|3001)\s*$' > /dev/null 2>&1; then
        echo "BLOCKED: $file contains banned external port default (3000/3001)"
        echo "  Use 4000/4001 instead. See docs/NETWORKING_STANDARDS.md"
        echo "  Matching lines:"
        echo "$STAGED_CONTENT" | grep -nP '^\s*default\s*=\s*(3000|3001)\s*$' | head -5
        echo ""
        ERRORS=$((ERRORS + 1))
    fi

    # Pattern 2: Docker compose host port mappings like "3000:3000" or "3001:3001"
    # Match "3000:XXXX" or "3001:XXXX" (host port is 3000/3001)
    if echo "$STAGED_CONTENT" | grep -nP '"\d*3000:\d+"|"\d*3001:\d+"' > /dev/null 2>&1; then
        # Exclude lines that are clearly internal (Traefik labels, healthchecks)
        MATCHES=$(echo "$STAGED_CONTENT" | grep -nP '"\d*3000:\d+"|"\d*3001:\d+"' | grep -v 'loadbalancer\|localhost\|internal' || true)
        if [ -n "$MATCHES" ]; then
            echo "BLOCKED: $file contains banned port mapping (3000/3001 as host port)"
            echo "  Use 4000/4001 instead. See docs/NETWORKING_STANDARDS.md"
            echo "  Matching lines:"
            echo "$MATCHES" | head -5
            echo ""
            ERRORS=$((ERRORS + 1))
        fi
    fi

    # Pattern 3: Shell variable defaults like DOKPLOY_PORT:-3000 or KUMA_PORT:-3001
    if echo "$STAGED_CONTENT" | grep -nP 'PORT:-30(00|01)\}' > /dev/null 2>&1; then
        echo "BLOCKED: $file contains banned port default in shell variable"
        echo "  Use 4000/4001 instead. See docs/NETWORKING_STANDARDS.md"
        echo "  Matching lines:"
        echo "$STAGED_CONTENT" | grep -nP 'PORT:-30(00|01)\}' | head -5
        echo ""
        ERRORS=$((ERRORS + 1))
    fi
done

if [ $ERRORS -gt 0 ]; then
    echo "============================================================"
    echo "  COMMIT BLOCKED: $ERRORS file(s) use banned ports 3000/3001"
    echo "  as external/host ports."
    echo ""
    echo "  Rule: External ports must use 4000 (Dokploy) and 4001"
    echo "  (Uptime Kuma). Internal container ports are allowed."
    echo ""
    echo "  See: docs/NETWORKING_STANDARDS.md#banned-external-ports"
    echo "============================================================"
    exit 1
fi

exit 0
