# Database
# Port 5434 to avoid conflicts with local 5432; DB name is shared 'kombify'
DATABASE_URL="postgresql://kombify:kombify@localhost:5434/kombify?schema=public"

# Firecrawl API (required for tool discovery)
# Get your API key at https://firecrawl.dev/
FIRECRAWL_API_KEY=""
FIRECRAWL_BASE_URL="https://api.firecrawl.dev/v1"

# n8n Integration (optional - for scheduled workflows)
N8N_EXECUTION_ID=""
N8N_WORKFLOW_ID=""

# OpenAI (optional - for AI enrichment)
OPENAI_API_KEY=""
